<%- include('partials/header') %>

<main id="main-content" class="pt-60 pb-60 bg-[#030303]">
    <div class="apple-container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-32">
            <div class="lg:col-span-12 text-center mb-60">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 mb-12">
                    Guanti Bianchi Service
                </div>
                <h1 class="text-7xl md:text-[160px] font-black tracking-tighter text-white italic-heading italic uppercase leading-[0.85]">
                    Absolute <br/>
                    <span class="text-white/20 not-italic">Care.</span>
                </h1>
            </div>

            <div class="lg:col-span-5 space-y-32">
                <p class="text-4xl text-white/50 font-light leading-relaxed italic-heading italic">
                    "We handle the mechanical, so you can experience the art. Every detail of your journey curated by the archive's specialists."
                </p>

                <div class="grid grid-cols-1 gap-16">
                    <% [
                        { icon: 'local_shipping', title: 'Global Transport', desc: 'Secure delivery to your villa or estate.' },
                        { icon: 'support_agent', title: '24/7 Mechanical', desc: 'On-call specialists for every mile driven.' },
                        { icon: 'explore', title: 'Route Curation', desc: 'Private maps through legendary Italian passes.' }
                    ].forEach(item => { %>
                        <div class="group flex items-start gap-12 border-b border-white/5 pb-12">
                            <span class="material-symbols-outlined text-4xl text-white/20 group-hover:text-white transition-colors duration-500"><%= item.icon %></span>
                            <div>
                                <h4 class="text-[12px] font-black uppercase tracking-[0.5em] text-white mb-4 italic-heading italic"><%= item.title %></h4>
                                <p class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] leading-relaxed"><%= item.desc %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="lg:col-span-7">
                <div class="apple-glass rounded-[100px] p-3 group">
                    <div class="aspect-[4/5] rounded-[88px] overflow-hidden bg-neutral-900 relative">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/1971_Lamborghini_Miura_P400_SV.jpg/1280px-1971_Lamborghini_Miura_P400_SV.jpg" alt="Concierge Care" class="w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 shadow-inner" />
                        <div class="absolute inset-x-20 bottom-20">
                             <div class="apple-glass p-16 rounded-[60px] backdrop-blur-3xl bg-black/40">
                                <p class="text-3xl text-white font-light leading-relaxed italic-heading italic mb-10">
                                    "Impeccable. The 275 GTB was waiting, perfectly tuned for the Tuscan sun."
                                </p>
                                <p class="text-[10px] font-black uppercase tracking-[0.6em] text-white/20">Archived Correspondence // 2025</p>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
