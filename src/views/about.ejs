<%- include('partials/header') %>

<main id="main-content" class="pt-60 pb-60 bg-[#030303]">
    <div class="apple-container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-32 mb-80">
            <div class="lg:col-span-12 text-center mb-60">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 mb-12">
                    Established Milan // 2018
                </div>
                <h1 class="text-7xl md:text-[160px] font-black tracking-tighter text-white italic-heading italic uppercase leading-[0.85]">
                    Preserving <br/>
                    <span class="text-white/20 not-italic">the Soul.</span>
                </h1>
            </div>

            <div class="lg:col-span-6">
                <div class="apple-glass rounded-[100px] overflow-hidden aspect-square p-3">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/1963_Ferrari_250_GTO_%28chassis_4153GT%29_2.95.jpg/1280px-1963_Ferrari_250_GTO_%28chassis_4153GT%29_2.95.jpg" alt="Milano Workshop" class="w-full h-full object-cover grayscale transition-all duration-1000 hover:grayscale-0 rounded-[88px]" />
                </div>
            </div>

            <div class="lg:col-span-6 space-y-24 pt-16">
                <h2 class="text-6xl font-black italic-heading italic text-white uppercase tracking-tighter leading-none italic-heading italic">The Italian <br/><span class="text-white/20 not-italic">Equation.</span></h2>
                <p class="text-3xl text-white/50 font-light leading-relaxed italic-heading italic">
                    "Founded with the sole purpose of archiving the automotive absolute. Every machine in our collection is a testament to the mid-century Italian golden age—where engineering met high art."
                </p>
                
                <div class="grid grid-cols-2 gap-12 pt-16 border-t border-white/5">
                    <div>
                        <h3 class="text-7xl font-black italic-heading italic text-white tracking-tighter mb-4 italic-heading italic">42</h3>
                        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20">Archived Icons</p>
                    </div>
                    <div>
                        <h3 class="text-7xl font-black italic-heading italic text-white tracking-tighter mb-4 italic-heading italic">12</h3>
                        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20">Global Hubs</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
