<section class="py-60 border-t border-white/5 bg-[#030303]">
    <div class="apple-container">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-12 mb-32">
            <h2 class="text-6xl md:text-[100px] font-black italic-heading italic uppercase tracking-tighter leading-[0.85]">
                Selected <br/>
                <span class="text-white/20 not-italic">Archive.</span>
            </h2>
            <a href="/collections" class="text-[10px] font-black uppercase tracking-[0.5em] text-white/40 hover:text-white transition-all border-b border-white/5 pb-2">Full Collection</a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            <% fleet.slice(0, 3).forEach(car => { %>
                <a href="/car/<%= car.id %>" class="group block">
                    <div class="apple-glass p-2 rounded-[60px] group-hover:scale-[1.01] mb-10 overflow-hidden transition-all duration-700">
                        <div class="aspect-[4/5] rounded-[52px] overflow-hidden bg-neutral-900 relative">
                            <img src="<%= car.image %>" alt="<%= car.name %>" class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000" loading="lazy" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="absolute bottom-12 left-12 opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-y-4 group-hover:translate-y-0">
                                <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white italic-heading italic">FROM €<%= car.price %> / DAY</p>
                            </div>
                        </div>
                    </div>
                    <div class="px-6 flex items-start justify-between">
                        <div>
                            <h3 class="text-3xl font-black italic-heading italic text-white uppercase tracking-tighter mb-2"><%= car.name %></h3>
                            <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20"><%= car.model %></p>
                        </div>
                        <span class="material-symbols-outlined text-white/10 group-hover:text-white transition-colors">north_east</span>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</section>
