<section class="relative min-h-[88vh] md:h-screen flex items-center justify-center overflow-hidden">
    <!-- Base Image Layer -->
    <div class="absolute inset-0 z-0">
        <img alt="Vintage Italian Spec" class="w-full h-full object-cover opacity-80" src="https://upload.wikimedia.org/wikipedia/commons/5/5f/1973_Ferrari_Daytona_365_GTB4_Blue_LC22.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-[#030303]"></div>
    </div>

    <!-- Content Layer -->
    <div class="relative z-10 text-center px-4 sm:px-6 max-w-5xl pt-20 md:pt-0">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[9px] sm:text-[10px] font-black uppercase tracking-[0.3em] sm:tracking-[0.4em] text-white/40 mb-8 md:mb-10">
            Heritage Archive // 1960s Italy
        </div>
        <h1 class="text-5xl sm:text-6xl md:text-[120px] text-white font-black italic-heading italic mb-6 md:mb-8 leading-[0.9] md:leading-[0.85] uppercase tracking-tight md:tracking-tighter">
            Drive a <br/>
            <span class="text-white/20 not-italic">Legend.</span>
        </h1>
        <p class="text-base sm:text-lg md:text-2xl text-white/50 md:text-white/40 mb-10 md:mb-16 max-w-2xl mx-auto font-light leading-relaxed italic-heading italic px-2 sm:px-0">
            Experience the definitive elegance of the 1960s. Curated Italian classics, delivered to your residence.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6 w-full sm:w-auto px-4 sm:px-0">
            <a href="/collections" class="btn-scuderia w-full sm:w-auto">Explore Fleet</a>
            <a href="/about" class="text-[10px] font-black uppercase tracking-[0.5em] text-white/40 hover:text-white transition-all border-b border-white/10 pb-2">The Narrative</a>
        </div>
    </div>

    <!-- Original Quick Search Bar (Apple-fied) -->
    <div class="absolute bottom-12 w-full px-6 z-20 hidden lg:block">
        <div class="max-w-5xl mx-auto apple-glass p-1.5 rounded-[40px] flex items-stretch gap-1">
            <div class="flex-1 flex items-center px-8 py-4 border-r border-white/5">
                <span class="material-symbols-outlined text-white/20 mr-4">location_on</span>
                <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-[0.4em] text-white/30 font-black">Region</span>
                    <input class="bg-transparent border-none p-0 focus:ring-0 text-white placeholder-white/10 text-xs italic italic-heading" placeholder="Tuscany / Amalfi" type="text"/>
                </div>
            </div>
            <div class="flex-1 flex items-center px-8 py-4 border-r border-white/5">
                <span class="material-symbols-outlined text-white/20 mr-4">calendar_today</span>
                <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-[0.4em] text-white/30 font-black">Timeline</span>
                    <input class="bg-transparent border-none p-0 focus:ring-0 text-white placeholder-white/10 text-xs italic italic-heading" placeholder="Select Period" type="text"/>
                </div>
            </div>
            <div class="flex-1 flex items-center px-8 py-4">
                <span class="material-symbols-outlined text-white/20 mr-4">database</span>
                <div class="flex flex-col">
                    <span class="text-[8px] uppercase tracking-[0.4em] text-white/30 font-black">Archive</span>
                    <select class="bg-transparent border-none p-0 focus:ring-0 text-white text-xs appearance-none pr-8 italic italic-heading">
                        <option class="bg-[#030303]">All Manufacturers</option>
                        <option class="bg-[#030303]">Ferrari</option>
                        <option class="bg-[#030303]">Lamborghini</option>
                        <option class="bg-[#030303]">Maserati</option>
                    </select>
                </div>
            </div>
            <button class="bg-white text-black px-12 rounded-[32px] font-black text-[10px] uppercase tracking-[0.3em] hover:bg-neutral-200 transition-colors">
                SEARCH
            </button>
        </div>
    </div>
</section>
