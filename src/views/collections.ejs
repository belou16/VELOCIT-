<%- include('partials/header') %>

<main id="main-content" class="pt-60 pb-60 bg-[#030303]">
    <div class="apple-container">
        <% const categories = ['all', ...new Set(fleet.map((car) => car.category))]; %>
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-24 border-b border-white/5 pb-24 mb-32">
            <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 mb-10">
                    The Archive // 1960-1969 // <%= fleet.length %> cars
                </div>
                <h1 class="text-7xl md:text-[140px] font-black tracking-tighter text-white italic-heading italic uppercase leading-[0.85]">
                    Proven <br/>
                    <span class="text-white/20 not-italic">Heritage.</span>
                </h1>
            </div>
            
            <div class="flex flex-wrap gap-4" id="filters" role="toolbar" aria-label="Filter cars by brand">
                <% categories.forEach(cat => { %>
                    <button class="filter-btn px-10 py-4 rounded-full border text-[10px] font-black uppercase tracking-[0.4em] transition-all duration-300 <%= cat === 'all' ? 'is-active bg-[#D4AF37]/20 text-[#F5F5DC] border-[#D4AF37]/60 shadow-[0_0_0_1px_rgba(212,175,55,0.25)]' : 'bg-white/5 text-white/50 border-white/10 hover:text-[#F5F5DC] hover:border-[#D4AF37]/40' %>" data-category="<%= cat %>" aria-pressed="<%= cat === 'all' ? 'true' : 'false' %>">
                        <%= cat %>
                    </button>
                <% }) %>
            </div>
        </div>

        <p id="fleet-count" class="text-[10px] font-black uppercase tracking-[0.35em] text-white/40 mb-10" aria-live="polite"><%= fleet.length %> vehicles displayed</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-40" id="fleet-grid">
            <% fleet.forEach(car => { %>
                <div class="car-card group" data-category="<%= car.category %>">
                    <a href="/car/<%= car.id %>" class="block">
                        <div class="apple-glass p-2 rounded-[64px] group-hover:scale-[1.01] mb-12 overflow-hidden transition-all duration-700">
                            <div class="aspect-[4/5] rounded-[56px] overflow-hidden bg-neutral-900 relative">
                                <img src="<%= car.image %>" alt="<%= car.name %>" class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-1000" loading="lazy" />
                                <div class="absolute top-12 left-12 apple-glass px-8 py-3 rounded-full text-[10px] font-black text-white italic-heading italic">
                                    €<%= car.price %> / DAY
                                </div>
                            </div>
                        </div>
                        <div class="px-8 flex items-start justify-between">
                            <div>
                                <h3 class="text-4xl font-black italic-heading italic text-white uppercase tracking-tighter mb-2"><%= car.name %></h3>
                                <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20"><%= car.model %></p>
                            </div>
                            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-white/10 italic italic-heading"><%= car.category %></span>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</main>

<script>
    const btns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.car-card');
    const fleetCount = document.getElementById('fleet-count');

    function applyFilter(cat) {
        let visibleCount = 0;

        btns.forEach((btn) => {
            const selected = btn.dataset.category === cat;
            btn.setAttribute('aria-pressed', selected ? 'true' : 'false');
            btn.classList.toggle('is-active', selected);
            btn.classList.toggle('bg-[#D4AF37]/20', selected);
            btn.classList.toggle('text-[#F5F5DC]', selected);
            btn.classList.toggle('border-[#D4AF37]/60', selected);
            btn.classList.toggle('shadow-[0_0_0_1px_rgba(212,175,55,0.25)]', selected);

            btn.classList.toggle('bg-white/5', !selected);
            btn.classList.toggle('text-white/50', !selected);
            btn.classList.toggle('border-white/10', !selected);
        });

        cards.forEach((card) => {
            const shouldShow = cat === 'all' || card.dataset.category === cat;
            card.style.display = shouldShow ? 'block' : 'none';
            if (shouldShow) visibleCount += 1;
        });

        fleetCount.textContent = `${visibleCount} vehicles displayed`;
    }
    
    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            applyFilter(btn.dataset.category);
        });
    });

    applyFilter('all');
</script>

<%- include('partials/footer') %>
