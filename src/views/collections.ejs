<%- include('partials/header') %>

<main class="pt-60 pb-60 bg-[#030303]">
    <div class="apple-container">
        <% const categories = ['all', ...new Set(fleet.map((car) => car.category))]; %>
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-24 border-b border-white/5 pb-24 mb-32">
            <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 mb-10">
                    The Archive // 1960-1969 // <%= fleet.length %> cars
                </div>
                <h1 class="text-7xl md:text-[140px] font-black tracking-tighter text-white italic-heading italic uppercase leading-[0.85]">
                    Proven <br/>
                    <span class="text-white/20 not-italic">Heritage.</span>
                </h1>
            </div>
            
            <div class="flex flex-wrap gap-4" id="filters">
                <% categories.forEach(cat => { %>
                    <button class="filter-btn px-10 py-4 rounded-full border border-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/30 hover:text-white transition-all duration-300 <%= cat === 'all' ? 'bg-white text-black border-transparent' : 'bg-white/5' %>" data-category="<%= cat %>">
                        <%= cat %>
                    </button>
                <% }) %>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-40" id="fleet-grid">
            <% fleet.forEach(car => { %>
                <div class="car-card group" data-category="<%= car.category %>">
                    <a href="/car/<%= car.id %>" class="block">
                        <div class="apple-glass p-2 rounded-[64px] group-hover:scale-[1.01] mb-12 overflow-hidden transition-all duration-700">
                            <div class="aspect-[4/5] rounded-[56px] overflow-hidden bg-neutral-900 relative">
                                <img src="<%= car.image %>" alt="<%= car.name %>" class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-1000" loading="lazy" />
                                <div class="absolute top-12 left-12 apple-glass px-8 py-3 rounded-full text-[10px] font-black text-white italic-heading italic">
                                    €<%= car.price %> / DAY
                                </div>
                            </div>
                        </div>
                        <div class="px-8 flex items-start justify-between">
                            <div>
                                <h3 class="text-4xl font-black italic-heading italic text-white uppercase tracking-tighter mb-2"><%= car.name %></h3>
                                <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20"><%= car.model %></p>
                            </div>
                            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-white/10 italic italic-heading"><%= car.category %></span>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</main>

<script>
    const btns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.car-card');
    
    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            btns.forEach(b => {
                b.classList.remove('bg-white', 'text-black', 'border-transparent');
                b.classList.add('bg-white/5', 'text-white/30', 'border-white/5');
            });
            btn.classList.add('bg-white', 'text-black', 'border-transparent');
            btn.classList.remove('bg-white/5', 'text-white/30', 'border-white/5');
            
            const cat = btn.dataset.category;
            cards.forEach(card => {
                if(cat === 'all' || card.dataset.category === cat) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });
</script>

<%- include('partials/footer') %>
