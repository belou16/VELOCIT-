<%- include('partials/header') %>

<main id="main-content" class="hero-gradient min-h-screen pt-48 pb-24 px-6">
    <div class="max-w-[1400px] mx-auto text-center mb-32">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 mb-10">
            <span class="flex h-1.5 w-1.5 rounded-full bg-blue-500"></span>
            Oltre la Guida
        </div>
        <h1 class="text-6xl md:text-8xl font-black text-white italic tracking-tighter uppercase mb-6 leading-none">
            Curated <br/>
            <span class="not-italic bg-clip-text text-transparent bg-gradient-to-b from-white to-white/30">Adventures.</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/50 max-w-2xl mx-auto font-light leading-relaxed">
            We don't just provide cars; we design memories. Discover our bespoke driving tours across the most legendary roads of the continent.
        </p>
    </div>

    <section class="max-w-[1400px] mx-auto space-y-48">
        <% [
            { 
                num: '01', 
                id: 'COASTAL RUN', 
                title: "The Amalfi Coast", 
                subtitle: "Heritage Tour", 
                img: "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Lancia_Motor_Club_AGM_2011_DSC_4294_-_Flickr_-_tonylanciabeta_%28cropped%29.jpg/1280px-Lancia_Motor_Club_AGM_2011_DSC_4294_-_Flickr_-_tonylanciabeta_%28cropped%29.jpg",
                desc: "Discover the winding roads of Southern Italy in a vintage Alfa Romeo. Stay in private villas, dine in Michelin-starred gardens, and experience the pure Dolce Vita."
            },
            { 
                num: '02', 
                id: 'MOUNTAIN PASS', 
                title: "The Alpine Pass", 
                subtitle: "Expedition", 
                img: "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c6/1961_Lancia_Flaminia_GT%2C_front_right.jpg/1280px-1961_Lancia_Flaminia_GT%2C_front_right.jpg",
                desc: "Conquer the Swiss and Italian Alps with our performance-tuned fleet. A high-altitude adventure through legendary mountain passes and crystal-clear lakes.",
                reverse: true
            }
        ].forEach(exp => { %>
            <div class="flex flex-col <%= exp.reverse ? 'lg:flex-row-reverse' : 'lg:flex-row' %> gap-24 items-center group">
                <div class="flex-1 space-y-10 <%= exp.reverse ? 'text-right' : '' %>">
                    <span class="text-blue-500 font-black text-xs tracking-[0.4em] uppercase"><%= exp.num %> / <%= exp.id %></span>
                    <h2 class="text-5xl md:text-7xl font-black text-white italic uppercase tracking-tighter leading-none">
                        <%= exp.title %> <br/>
                        <span class="not-italic bg-clip-text text-transparent bg-gradient-to-b from-white to-white/40"><%= exp.subtitle %></span>
                    </h2>
                    <p class="text-white/50 text-xl font-light leading-relaxed max-w-xl <%= exp.reverse ? 'ml-auto' : '' %>">
                        <%= exp.desc %>
                    </p>
                    <button class="glass border border-white/10 px-10 py-5 rounded-full text-white/50 hover:text-white transition-all text-xs font-black uppercase tracking-[0.3em] hover:bg-white/10">
                        Explore Adventure
                    </button>
                </div>
                <div class="flex-1 w-full">
                    <div class="glass p-3 rounded-[60px] shadow-3xl shadow-blue-500/5 group-hover:scale-[1.01] transition-transform duration-1000">
                        <div class="aspect-[16/9] rounded-[48px] overflow-hidden bg-[#050505] relative">
                            <img src="<%= exp.img %>" alt="<%= exp.title %>" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </section>
</main>

<%- include('partials/footer') %>
