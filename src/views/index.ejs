<%- include('partials/header') %>
<%- include('partials/hero') %>

<!-- Selective Collection -->
<section class="py-40 px-6 max-w-[1400px] mx-auto">
    <div class="flex flex-col md:flex-row items-end justify-between mb-24 gap-8">
        <div>
            <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 mb-6">Archival Selection</p>
            <h2 class="text-6xl md:text-8xl font-black text-white italic-heading italic uppercase tracking-tighter leading-none">The 1960s <br/><span class="text-white/20 not-italic">Archive.</span></h2>
        </div>
        <a class="text-[10px] font-black uppercase tracking-[0.5em] text-white/30 hover:text-white transition-all border-b border-white/5 pb-2 italic-heading italic" href="/collections">
            Full Collection →
        </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        <% fleet.slice(0, 3).forEach(car => { %>
            <div class="group">
                <a href="/car/<%= car.id %>" class="block">
                    <div class="apple-glass p-2 rounded-[60px] mb-10 overflow-hidden group-hover:scale-[1.01] transition-transform duration-700">
                        <div class="aspect-[4/5] rounded-[52px] overflow-hidden bg-neutral-900 relative">
                            <img alt="<%= car.name %>" class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-1000" src="<%= car.image %>" loading="lazy" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            <div class="absolute top-8 right-8 apple-glass px-5 py-2 rounded-full text-[9px] font-black text-white italic-heading italic uppercase tracking-widest">
                                €<%= car.price %> / DAY
                            </div>
                        </div>
                    </div>
                    <div class="px-6 flex items-start justify-between">
                        <div>
                            <h3 class="text-3xl font-black italic-heading italic text-white uppercase tracking-tighter mb-2"><%= car.name %></h3>
                            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20"><%= car.model %></p>
                        </div>
                        <span class="material-symbols-outlined text-white/10 group-hover:text-white group-hover:translate-x-1 transition-all">north_east</span>
                    </div>
                </a>
            </div>
        <% }) %>
    </div>
</section>

<!-- Fundamental Services (Style "avant" mais Design "Apple") -->
<section class="bg-white/5 border-y border-white/5 py-40">
    <div class="max-w-[1400px] mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-24">
        <div class="text-center group">
            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-10 apple-glass">
                <span class="material-symbols-outlined text-white/20 text-3xl group-hover:text-white transition-colors">local_shipping</span>
            </div>
            <h4 class="text-2xl font-black mb-6 text-white italic-heading italic uppercase tracking-tighter">Concierge Hub</h4>
            <p class="text-white/40 font-light leading-relaxed text-lg italic-heading italic">Your machine, delivered to your Tuscan driveway or private airfield with absolute precision.</p>
        </div>
        <div class="text-center group">
            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-10 apple-glass">
                <span class="material-symbols-outlined text-white/20 text-3xl group-hover:text-white transition-colors">verified_user</span>
            </div>
            <h4 class="text-2xl font-black mb-6 text-white italic-heading italic uppercase tracking-tighter">Verified Spec</h4>
            <p class="text-white/40 font-light leading-relaxed text-lg italic-heading italic">Comprehensive heritage coverage included for every mile, focusing on historical authenticity.</p>
        </div>
        <div class="text-center group">
            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-10 apple-glass">
                <span class="material-symbols-outlined text-white/20 text-3xl group-hover:text-white transition-colors">history_edu</span>
            </div>
            <h4 class="text-2xl font-black mb-6 text-white italic-heading italic uppercase tracking-tighter">Pure Motoring</h4>
            <p class="text-white/40 font-light leading-relaxed text-lg italic-heading italic">Period-correct Italian interiors and V12 engines, meticulously archived for reliable performance.</p>
        </div>
    </div>
</section>

<!-- Original Presence Section (Apple-fied) -->
<section class="py-40 px-6 max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-32 items-center">
    <div>
        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 mb-10">Direct Network</p>
        <h2 class="text-6xl md:text-8xl font-black text-white mb-12 italic-heading italic leading-none uppercase tracking-tighter">The Amalfi <br/><span class="text-white/20 not-italic">Connection.</span></h2>
        <div class="space-y-8">
            <div class="p-10 apple-glass rounded-[40px] hover:border-white/20 transition-all cursor-pointer group">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-2xl font-black text-white italic-heading italic uppercase tracking-tighter">The Amalfi Coast, IT</span>
                    <span class="material-symbols-outlined text-white/20 group-hover:text-white transition-colors">explore</span>
                </div>
                <p class="text-white/30 text-sm italic-heading italic">Our flagship Mediterranean hub offering coastal route experiences in historic Ferraris.</p>
            </div>
            <div class="p-10 apple-glass rounded-[40px] hover:border-white/20 transition-all cursor-pointer group">
                <div class="flex justify-between items-center mb-4">
                    <span class="text-2xl font-black text-white italic-heading italic uppercase tracking-tighter">Tuscany Valley, IT</span>
                    <span class="material-symbols-outlined text-white/20 group-hover:text-white transition-colors">explore</span>
                </div>
                <p class="text-white/30 text-sm italic-heading italic">Classic Alfa Romeos curated for the ultimate wine country road trip across the hills.</p>
            </div>
        </div>
    </div>
    <div class="relative h-[700px] rounded-[80px] overflow-hidden apple-glass p-3">
        <div class="w-full h-full rounded-[68px] overflow-hidden relative">
            <img class="w-full h-full object-cover grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-1000" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCrKP0XBtpviB-0P4ISF7cfn6Ek1R8KQejooO_HJsV8PMs9rZKZ0dOZvMG_oG9KdxY3mCREHqMlrmddgE7S5EOoDtAdwJdTcLLBdoQqW6L13t6NdTXx3Z3n-jbR5RarI2sDrwAuuLUYgnyAlEyGuFt2XLlzRqWdYIqaI5nosqqNktc8C84BjGNN5d2U-Ug8XxKSfehhfjaSOfhJYewalRqBuWaRYLDQaO2soY_0dJf6NC9lqnfROHGEJzofBeKP6fMb-leEwoCWpYQ" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
