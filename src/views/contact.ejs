<%- include('partials/header') %>

<main id="main-content" class="pt-60 pb-60 bg-[#030303]">
    <div class="apple-container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-32">
            
            <div class="lg:col-span-12 text-center mb-60">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/5 bg-white/5 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 mb-12">
                    Direct Liaison
                </div>
                <h1 class="text-7xl md:text-[160px] font-black tracking-tighter text-white italic-heading italic uppercase leading-[0.85] mb-20">
                    Connect to <br/>
                    <span class="text-white/20 not-italic">Legacy.</span>
                </h1>
            </div>

            <div class="lg:col-span-5 space-y-40">
                <p class="text-4xl text-white/40 font-light leading-relaxed italic-heading italic">
                    "Ready to curate your heritage experience? Our team is available for private consultations."
                </p>

                <div class="space-y-20">
                    <% [
                        { label: 'Correspondence', value: 'concierge@velocita.luxury' },
                        { label: 'Location', value: 'Modena // Italy' },
                        { label: 'Journal', value: '@velocita.italia' }
                    ].forEach(item => { %>
                        <div class="border-b border-white/5 pb-12">
                            <p class="text-[10px] font-black uppercase tracking-[0.6em] text-white/20 mb-6"><%= item.label %></p>
                            <p class="text-4xl font-black italic-heading italic text-white uppercase tracking-tighter"><%= item.value %></p>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="lg:col-span-7">
                <div class="apple-glass p-28 rounded-[100px]">
                    <form action="#" class="space-y-20">
                        <div class="space-y-6">
                            <label class="text-[10px] font-black uppercase tracking-[0.6em] text-white/20">Identity</label>
                            <input type="text" placeholder="Your Name" class="w-full bg-transparent border-b border-white/10 py-8 text-3xl font-black italic-heading italic uppercase focus:outline-none focus:border-white transition-colors placeholder:text-white/5" />
                        </div>
                        <div class="space-y-6">
                            <label class="text-[10px] font-black uppercase tracking-[0.6em] text-white/20">Gateway</label>
                            <input type="email" placeholder="Email Address" class="w-full bg-transparent border-b border-white/10 py-8 text-3xl font-black italic-heading italic uppercase focus:outline-none focus:border-white transition-colors placeholder:text-white/5" />
                        </div>
                        <div class="space-y-6">
                            <label class="text-[10px] font-black uppercase tracking-[0.6em] text-white/20">Context</label>
                            <textarea rows="4" placeholder="Your Inquiry" class="w-full bg-transparent border-b border-white/10 py-8 text-3xl font-black italic-heading italic uppercase focus:outline-none focus:border-white transition-colors placeholder:text-white/5 resize-none"></textarea>
                        </div>
                        <button type="submit" class="btn-apple w-full py-8 text-[11px] tracking-[0.6em]">Transmit Inquiry</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
