<%- include('partials/header') %>

<main id="main-content" class="min-h-screen pt-40 pb-60 bg-[#030303]">
    <div class="apple-container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-32">
            
            <!-- Visual Specimen -->
            <div class="lg:col-span-7 space-y-12">
                <div class="apple-glass p-3 rounded-[80px] group transition-transform duration-1000">
                    <div class="aspect-[16/9] rounded-[68px] overflow-hidden bg-neutral-900 relative">
                        <img src="<%= car.image %>" alt="<%= car.name %>" class="w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60"></div>
                        
                        <div class="absolute bottom-12 left-12 apple-glass px-10 py-5 rounded-full">
                            <span class="text-[10px] font-black uppercase tracking-[0.5em] text-white">Archival Entry // Spec No. <%= car.id %></span>
                        </div>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-12">
                    <div class="apple-glass p-16 rounded-[60px] aspect-square flex flex-col justify-end">
                        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 mb-6">Mechanical</p>
                        <p class="text-5xl font-black italic-heading italic text-white uppercase tracking-tighter">Manual/4</p>
                    </div>
                    <div class="apple-glass p-16 rounded-[60px] aspect-square flex flex-col justify-end">
                        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 mb-6">Signature</p>
                        <p class="text-5xl font-black italic-heading italic text-white uppercase tracking-tighter"><%= car.category %></p>
                    </div>
                </div>
            </div>

            <!-- Detail Archive -->
            <div class="lg:col-span-5 pt-12">
                <div class="sticky top-40 space-y-32">
                    <div>
                        <h1 class="text-7xl md:text-[110px] font-black italic-heading italic text-white uppercase tracking-tighter leading-[0.85] mb-12"><%= car.name %></h1>
                        <p class="text-white/40 text-[11px] font-black uppercase tracking-[0.5em]"><%= car.model %></p>
                    </div>

                    <p class="text-3xl text-white/50 font-light leading-relaxed italic-heading italic">
                        "<%= car.description %>"
                    </p>

                    <div class="space-y-16">
                        <div class="flex items-end justify-between border-b border-white/5 pb-10">
                            <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20">Archival Rate</p>
                            <p class="text-5xl font-black italic-heading italic text-white uppercase tracking-tighter">€<%= car.price %></p>
                        </div>
                        <div class="flex items-end justify-between border-b border-white/5 pb-10">
                            <p class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20">Heritage</p>
                            <p class="text-5xl font-black italic-heading italic text-white uppercase tracking-tighter">Verified</p>
                        </div>
                    </div>

                    <div class="flex gap-10 pt-16">
                        <a href="/contact" class="btn-apple flex-1 text-center">Inquire Access</a>
                        <a href="/collections" class="nav-link border-b border-white/5 pb-2">Archive</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
